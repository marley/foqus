{
  "name": "Foqus",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "foqus_extension.png"
  },
  "background": {
      "service_worker": "background/background.js"
  },
  "content_scripts": [{
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
  }],
  "permissions": [
    "storage",
    "webRequest",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"]
}