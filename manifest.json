{
  "name": "Foqus",
  "description": "Track your sites of distraction and reshape your browsing habits",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "foqus_extension.png"
  },
  "background": {
      "service_worker": "background/background.js"
  },
  "permissions": [
    "storage",
    "webRequest",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"]
}